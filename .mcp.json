{
    "mcpServers": {
        "laravel-boost": {
            "command": "php",
            "args": [
                "artisan",
                "boost:mcp"
            ]
        },
        "jazeos": {
            "type": "http",
            "url": "${JAZEOS_MCP_URL:-http://localhost/mcp/jazeos}",
            "headers": {
                "Authorization": "Bearer ${JAZEOS_AGENT_TOKEN}"
            }
        }
    }
}
