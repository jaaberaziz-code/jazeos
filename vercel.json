{
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.php" },
    { "src": "/build/assets/(.*)", "dest": "/build/assets/$1" },
    { "src": "/(.*)", "dest": "/api/index.php" }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index.php" }
  ],
  "buildCommand": "pnpm run build",
  "outputDirectory": "public",
  "public": true
}
